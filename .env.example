# .env.example — copy this to .env and fill in your real key
# .env is gitignored — your real key is never committed
#
# Local dev / CLI reads the key from .env. The deployed dashboard has no .env,
# so its Live Review tab uses the BYOK paste panel instead (env-first: if .env
# supplies the key, the panel stays hidden).

OPENAI_API_KEY=
